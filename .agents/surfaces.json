{
  "version": 1,
  "surfaces": [
    {
      "surface_id": "checked-in-plugin-export",
      "description": "Checked-in plugin install surface and root marketplace artifacts derived from repo-owned source paths.",
      "source_paths": [
        "README.md",
        "packaging/**",
        "skills/public/**",
        "skills/support/**",
        "profiles/**",
        "presets/**",
        "integrations/**",
        "scripts/**",
        "runtime_bootstrap.py",
        "skill_runtime_bootstrap.py"
      ],
      "derived_paths": [
        "plugins/charness/**",
        ".claude-plugin/marketplace.json",
        ".agents/plugins/marketplace.json"
      ],
      "sync_commands": [
        "python3 scripts/sync_root_plugin_manifests.py --repo-root ."
      ],
      "verify_commands": [
        "python3 scripts/validate_packaging.py --repo-root .",
        "python3 scripts/validate_packaging_committed.py --repo-root ."
      ],
      "notes": [
        "Edit the repo-owned source path, not the checked-in plugin export.",
        "If a derived artifact changes, regenerate it and commit the result."
      ],
      "generated_markdown": [
        {
          "derived_path": "plugins/charness/README.md",
          "source_path": "README.md",
          "generator": "python3 scripts/sync_root_plugin_manifests.py --repo-root .",
          "sync_command": "python3 scripts/sync_root_plugin_manifests.py --repo-root ."
        }
      ]
    },
    {
      "surface_id": "repo-markdown",
      "description": "Repo-owned markdown docs and generated markdown copies that need link, lint, and secret checks.",
      "source_paths": [
        "AGENTS.md",
        "CLAUDE.md",
        ".agents/command-docs.yaml",
        ".gitleaks.toml",
        ".secretlintignore",
        "README.md",
        "charness-artifacts/**/*.md",
        "docs/*.md",
        "docs/**/*.md",
        "evals/*.md",
        "evals/**/*.md",
        "packaging/**/*.md",
        "integrations/**/*.md",
        "skills/**/*.md"
      ],
      "derived_paths": [
        "plugins/charness/**/*.md"
      ],
      "sync_commands": [],
      "verify_commands": [
        "python3 scripts/check_doc_links.py --repo-root .",
        "python3 scripts/check_command_docs.py --repo-root .",
        "./scripts/check-markdown.sh",
        "./scripts/check-secrets.sh"
      ],
      "notes": [
        "Keep human-facing docs in sync with generated markdown copies.",
        "Run the markdown and link checks before closeout."
      ]
    },
    {
      "surface_id": "prompt-behavior-proof",
      "description": "Prompt-affecting instruction surfaces must refresh the checked-in cautilus proof artifact.",
      "source_paths": [
        "AGENTS.md",
        "CLAUDE.md",
        ".agents/*-adapter.yaml",
        ".agents/cautilus-adapters/*.yaml",
        "evals/cautilus/instruction-surface-cases.json",
        "evals/cautilus/whole-repo-routing.fixture.json",
        "skills/public/*/SKILL.md",
        "skills/public/*/references/**",
        "skills/support/*/SKILL.md",
        "skills/support/*/references/**"
      ],
      "derived_paths": [
        "charness-artifacts/cautilus/latest.md"
      ],
      "sync_commands": [],
      "verify_commands": [
        "python3 scripts/validate_cautilus_proof.py --repo-root ."
      ],
      "notes": [
        "Prompt-affecting changes must refresh `charness-artifacts/cautilus/latest.md`, but adapter policy decides whether cautilus may run automatically, must ask, or may adapt by cost and proof kind.",
        "High-leverage prompt changes should leave both regression proof and scenario-review notes when the adapter asks for more than routing preservation.",
        "Behavior-improvement claims must also record a baseline compare path in the cautilus artifact."
      ]
    },
    {
      "surface_id": "skill-packages",
      "description": "Public and support skill packages plus their helper scripts.",
      "source_paths": [
        "skills/public/**",
        "skills/support/**"
      ],
      "derived_paths": [
        "plugins/charness/skills/**",
        "plugins/charness/support/**",
        "charness-artifacts/find-skills/latest.md",
        "charness-artifacts/find-skills/latest.json"
      ],
      "sync_commands": [],
      "verify_commands": [
        "python3 scripts/validate_skills.py --repo-root .",
        "python3 -m py_compile skills/public/*/scripts/*.py skills/support/*/scripts/*.py"
      ],
      "notes": [
        "Skill trigger contracts stay source-owned under skills/, not under plugins/."
      ]
    },
    {
      "surface_id": "public-skill-policy",
      "description": "Public skill classification policy and validator that must stay aligned with the current public skill set.",
      "source_paths": [
        "skills/public/**",
        "docs/public-skill-validation.json",
        "docs/public-skill-validation.md",
        "scripts/public_skill_validation_lib.py",
        "scripts/validate_public_skill_validation.py",
        "scripts/suggest_public_skill_validation.py"
      ],
      "derived_paths": [],
      "sync_commands": [],
      "verify_commands": [
        "python3 scripts/validate_public_skill_validation.py --repo-root ."
      ],
      "notes": [
        "New, renamed, or reclassified public skills must be reflected in `docs/public-skill-validation.json` before closeout."
      ]
    },
    {
      "surface_id": "public-skill-dogfood",
      "description": "Checked-in consumer dogfood cases for public skills and the validator that keeps them aligned with current skill contracts.",
      "source_paths": [
        "skills/public/**",
        "docs/public-skill-dogfood.json",
        "docs/public-skill-dogfood.md",
        "scripts/public_skill_dogfood_lib.py",
        "scripts/suggest_public_skill_dogfood.py",
        "scripts/validate_public_skill_dogfood.py"
      ],
      "derived_paths": [],
      "sync_commands": [],
      "verify_commands": [
        "python3 scripts/validate_public_skill_dogfood.py --repo-root ."
      ],
      "notes": [
        "When a reviewed consumer dogfood case drifts from current skill contracts, refresh the scaffold first and only then update the checked-in review observations."
      ]
    },
    {
      "surface_id": "profiles-and-presets",
      "description": "Profile and preset bundles that define packaged defaults.",
      "source_paths": [
        "profiles/**",
        "presets/**"
      ],
      "derived_paths": [
        "plugins/charness/profiles/**",
        "plugins/charness/presets/**"
      ],
      "sync_commands": [],
      "verify_commands": [
        "python3 scripts/validate_profiles.py --repo-root .",
        "python3 scripts/validate_presets.py --repo-root ."
      ],
      "notes": [
        "Do not leave packaged defaults pointing at missing artifacts."
      ]
    },
    {
      "surface_id": "adapters",
      "description": "Repo-local adapter contracts and adapter helper libraries.",
      "source_paths": [
        ".agents/*-adapter.yaml",
        ".agents/cautilus-adapters/*.yaml",
        "scripts/adapter*_lib.py",
        "scripts/adapter_init_lib.py",
        "scripts/simple_skill_adapter_lib.py"
      ],
      "derived_paths": [],
      "sync_commands": [],
      "verify_commands": [
        "python3 scripts/validate_adapters.py --repo-root ."
      ],
      "notes": [
        "Adapter contracts should stay machine-readable and loadable."
      ]
    },
    {
      "surface_id": "surface-obligations",
      "description": "Repo-owned changed-surface manifest that drives slice closeout obligations.",
      "source_paths": [
        ".agents/surfaces.json"
      ],
      "derived_paths": [],
      "sync_commands": [],
      "verify_commands": [
        "python3 scripts/validate_surfaces.py --repo-root ."
      ],
      "notes": [
        "Keep the surfaces manifest aligned with real repo-owned source and derived obligations."
      ]
    },
    {
      "surface_id": "cautilus-chatbot-proposals",
      "description": "Checked-in long-context chatbot proposal packets and their current-pointer artifacts.",
      "source_paths": [
        "evals/cautilus/chatbot-scenario-proposal-inputs.json",
        "scripts/eval_cautilus_chatbot_proposals.py",
        "scripts/cautilus_scenarios_lib.py",
        "scripts/validate_cautilus_scenarios.py"
      ],
      "derived_paths": [
        "charness-artifacts/cautilus/chatbot-proposals/**"
      ],
      "sync_commands": [],
      "verify_commands": [
        "python3 scripts/validate_cautilus_scenarios.py --repo-root .",
        "python3 scripts/eval_cautilus_chatbot_proposals.py --repo-root . --json"
      ],
      "notes": [
        "Keep the checked-in proposal packet and the visible current-pointer artifact in sync.",
        "This surface is proposal-mining evidence, not yet a compare-backed benchmark claim."
      ]
    },
    {
      "surface_id": "cautilus-chatbot-benchmark",
      "description": "A/B comparison runner and current-pointer artifacts for long-context chatbot proposal benchmarking.",
      "source_paths": [
        ".agents/cautilus-adapters/chatbot-benchmark.yaml",
        "scripts/eval_cautilus_chatbot_compare.py",
        "scripts/eval_cautilus_chatbot_proposals.py"
      ],
      "derived_paths": [
        "charness-artifacts/cautilus/chatbot-benchmark/**"
      ],
      "sync_commands": [],
      "verify_commands": [
        "python3 scripts/eval_cautilus_chatbot_compare.py --repo-root . --baseline-repo . --candidate-repo . --output-dir /tmp/charness-cautilus-chatbot-benchmark-self-compare"
      ],
      "notes": [
        "Keep compare artifacts explicit about baseline versus candidate and about proposal keys omitted by the product's current ranking cap."
      ]
    },
    {
      "surface_id": "debug-seam-risk-index",
      "description": "Generated source-linked index over debug artifact seam-risk fields.",
      "source_paths": [
        "charness-artifacts/debug/*.md",
        "scripts/build_debug_seam_risk_index.py"
      ],
      "derived_paths": [
        "charness-artifacts/debug/seam-risk-index.json"
      ],
      "sync_commands": [
        "python3 scripts/build_debug_seam_risk_index.py --repo-root . --write"
      ],
      "verify_commands": [
        "python3 scripts/build_debug_seam_risk_index.py --repo-root . --check"
      ],
      "notes": [
        "The index must link back to source debug artifacts and must not replace incident records with a single risk score."
      ]
    },
    {
      "surface_id": "retro-lesson-selection-index",
      "description": "Generated advisory index for source-linked retro lesson digest selection.",
      "source_paths": [
        "charness-artifacts/retro/*.md",
        "scripts/recent_lessons_lib.py",
        "scripts/build_retro_lesson_selection_index.py",
        "scripts/retro_persistence_lib.py",
        "skills/public/retro/scripts/refresh_recent_lessons.py"
      ],
      "derived_paths": [
        "charness-artifacts/retro/lesson-selection-index.json"
      ],
      "sync_commands": [
        "python3 scripts/build_retro_lesson_selection_index.py --repo-root . --write"
      ],
      "verify_commands": [
        "python3 scripts/build_retro_lesson_selection_index.py --repo-root . --check"
      ],
      "notes": [
        "The index is advisory source-linked selection evidence; it must not replace dated retro artifacts or make `recent-lessons.md` opaque."
      ]
    },
    {
      "surface_id": "executable-specs",
      "description": "Repo-owned specdown executable acceptance specs and their config.",
      "source_paths": [
        "specdown.json",
        "specs/**"
      ],
      "derived_paths": [],
      "sync_commands": [],
      "verify_commands": [
        "specdown run -quiet -no-report"
      ],
      "notes": [
        "Keep executable specs focused on stable operator-facing behavior; avoid adding adapters until setup or JSON extraction repeats."
      ]
    },
    {
      "surface_id": "integrations-and-control-plane",
      "description": "Integration manifests and control-plane helper scripts.",
      "source_paths": [
        "integrations/**",
        "scripts/control_plane_lib.py",
        "scripts/control_plane_render.py",
        "scripts/install_provenance_lib.py",
        "scripts/install_tools.py",
        "scripts/support_sync_lib.py",
        "scripts/sync_support.py",
        "scripts/update_tools.py",
        "scripts/upstream_release_lib.py"
      ],
      "derived_paths": [
        ".charness/**/*.json",
        "plugins/charness/integrations/**",
        "plugins/charness/scripts/**"
      ],
      "sync_commands": [],
      "verify_commands": [
        "python3 scripts/validate_integrations.py --repo-root .",
        "python3 scripts/sync_support.py --repo-root . --json",
        "python3 scripts/update_tools.py --repo-root . --json"
      ],
      "notes": [
        "Prefer dry-run capable control-plane checks before claiming the integration surface is healthy."
      ]
    },
    {
      "surface_id": "maintainer-hooks",
      "description": "Repo-owned maintainer hook and hook bootstrap validation.",
      "source_paths": [
        ".githooks/**",
        "scripts/install-git-hooks.sh",
        "scripts/validate_maintainer_setup.py"
      ],
      "derived_paths": [],
      "sync_commands": [],
      "verify_commands": [
        "python3 scripts/validate_maintainer_setup.py --repo-root ."
      ],
      "notes": [
        "Maintainer-local hook enforcement should fail closed when the clone drifts."
      ]
    },
    {
      "surface_id": "repo-python",
      "description": "Repo-owned Python code and tests.",
      "source_paths": [
        ".gitignore",
        "pyproject.toml",
        "charness",
        "scripts/**/*.py",
        "tests/*.py",
        "tests/**/*.py",
        "runtime_bootstrap.py",
        "skill_runtime_bootstrap.py"
      ],
      "derived_paths": [
        "plugins/charness/scripts/**/*.py"
      ],
      "sync_commands": [],
      "verify_commands": [
        "ruff check charness scripts tests skills/public/*/scripts skills/support/*/scripts",
        "pytest -q tests/quality_gates tests/control_plane tests/test_*.py tests/charness_cli/test_doctor_cache_selection.py tests/charness_cli/test_tool_lifecycle.py"
      ],
      "notes": [
        "Use targeted tests when iterating, but close out on the strongest standing Python gates the slice touched."
      ]
    }
  ]
}
