{
  "schema_version": "1",
  "tool_id": "specdown",
  "kind": "external_binary",
  "display_name": "specdown",
  "summary": "Executable specification runner that turns Markdown specs into runnable tests and reports.",
  "upstream_repo": "corca-ai/specdown",
  "homepage": "https://github.com/corca-ai/specdown",
  "platforms": [
    "linux",
    "macos"
  ],
  "status": "active",
  "lifecycle": {
    "install": {
      "mode": "script",
      "commands": [
        "curl -fsSL https://raw.githubusercontent.com/corca-ai/specdown/main/install.sh | sh"
      ],
      "install_url": "https://github.com/corca-ai/specdown",
      "docs_url": "https://github.com/corca-ai/specdown",
      "notes": [
        "Preferred install paths are the upstream install script or `go install`.",
        "Keep install method host-controlled instead of baking one package manager into charness."
      ]
    },
    "update": {
      "mode": "script",
      "commands": [
        "curl -fsSL https://raw.githubusercontent.com/corca-ai/specdown/main/install.sh | sh"
      ],
      "docs_url": "https://github.com/corca-ai/specdown/releases",
      "notes": [
        "Use the same mechanism that originally installed the binary."
      ]
    }
  },
  "checks": {
    "detect": {
      "commands": [
        "specdown version"
      ],
      "success_criteria": [
        "exit_code:0"
      ],
      "failure_hint": "Install specdown from the upstream repo or releases page."
    }
  },
  "access_modes": [
    "binary",
    "human-only",
    "degraded"
  ],
  "intent_triggers": [
    "*.spec.md",
    ".spec.md",
    "docs/specs",
    "run:shell",
    "doctest",
    "check table",
    "check:jq",
    "specdown report",
    "specdown HTML report",
    "report.json",
    "executable spec",
    "spec syntax",
    "adapter check",
    "specdown -filter",
    "reduce full specdown run cost"
  ],
  "strong_intent_triggers": [
    "*.spec.md",
    ".spec.md",
    "docs/specs",
    "run:shell",
    "check:jq",
    "specdown",
    "specdown report",
    "specdown HTML report",
    "specdown -filter",
    "executable spec",
    "spec syntax"
  ],
  "version_expectation": {
    "policy": "advisory",
    "constraint": "Prefer a recent upstream-supported release.",
    "detected_by": "stdout"
  },
  "package_managers": {
    "go": {
      "package_name": "github.com/corca-ai/specdown/cmd/specdown",
      "notes": [
        "Upstream documents `go install github.com/corca-ai/specdown/cmd/specdown@latest`."
      ]
    }
  },
  "support_skill_source": {
    "source_type": "upstream_repo",
    "path": "cmd/specdown/skills/specdown",
    "ref": "main",
    "notes": [
      "Prefer the upstream Specdown support skill instead of keeping a vendored Charness copy.",
      "The installed Charness plugin materializes this skill under `support/specdown/` during update or support sync."
    ]
  },
  "degradation": {
    "when_missing": [
      "Executable spec workflows should degrade to prose-only review or alternate test harnesses.",
      "Do not claim spec execution or report generation succeeded without the binary."
    ],
    "when_version_mismatch": [
      "Treat report or adapter drift as a manual review point before trusting results."
    ]
  }
}
