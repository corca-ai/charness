def resolve_config_home(home_root: Path) -> Path:
    override = os.environ.get("CHARNESS_CONFIG_HOME")
    if override:
        return Path(override).expanduser().resolve()
    xdg_root = os.environ.get("XDG_CONFIG_HOME")
    if xdg_root:
        return Path(xdg_root).expanduser().resolve()
    return home_root / ".config"


def resolve_state_home(home_root: Path) -> Path:
    override = os.environ.get("CHARNESS_STATE_HOME")
    if override:
        return Path(override).expanduser().resolve()
    xdg_root = os.environ.get("XDG_STATE_HOME")
    if xdg_root:
        return Path(xdg_root).expanduser().resolve()
    return home_root / ".local" / "state"


