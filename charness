def resolve_capability(
    *,
    home_root: Path,
    charness_repo_root: Path,
    target_repo_root: Path,
    logical_id: str,
) -> dict[str, object]:
    profiles_payload = load_capability_profiles(home_root)
    bindings_payload = load_repo_bindings(home_root)
    profiles = profiles_payload["profiles"]
    bindings = bindings_payload["repos"]
    binding_key = None
    binding_map: dict[str, str] | None = None
    for candidate in repo_binding_keys(target_repo_root):
        repo_binding = bindings.get(candidate)
        if isinstance(repo_binding, dict) and logical_id in repo_binding:
            binding_key = candidate
            binding_map = repo_binding
            break
    if binding_map is None or binding_key is None:
        guidance = "\n".join(capability_setup_guidance(home_root))
        raise CharnessError(
            f"No repo binding for `{logical_id}` matched `{target_repo_root}`.\n"
            f"Tried repo keys: {', '.join(repo_binding_keys(target_repo_root))}\n{guidance}"
        )
    profile_id = binding_map[logical_id]
    profile = profiles.get(profile_id)
    if not isinstance(profile, dict):
        guidance = "\n".join(capability_setup_guidance(home_root))
        raise CharnessError(
            f"Repo binding `{binding_key}` points `{logical_id}` at unknown profile `{profile_id}`.\n{guidance}"
        )
    providers = provider_index(charness_repo_root)
    provider_id = profile["provider"]
    provider = providers.get(provider_id)
    if provider is None:
        raise CharnessError(
            f"Profile `{profile_id}` points at unknown provider `{provider_id}` in `{charness_repo_root}`."
        )
    env_bindings = profile.get("env_bindings", {})
    env_status = {
        target_env: {
            "source_env": source_env,
            "present": source_env_present(source_env),
        }
        for target_env, source_env in env_bindings.items()
    }
    return {
        "logical_id": logical_id,
        "target_repo_root": str(target_repo_root),
        "candidate_repo_keys": repo_binding_keys(target_repo_root),
        "matched_repo_key": binding_key,
        "profile_id": profile_id,
        "provider_id": provider_id,
        "provider_kind": provider.get("kind"),
        "provider_manifest_path": provider.get("manifest_path"),
        "access_mode_preference": profile.get("access_mode_preference", []),
        "env_bindings": env_bindings,
        "env_binding_status": env_status,
        "capability_profiles_path": profiles_payload["path"],
        "repo_bindings_path": bindings_payload["path"],
    }


