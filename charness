    return home_root / ".codex" / "plugins" / PACKAGE_ID


def legacy_plugin_root(home_root: Path) -> Path:
    return home_root / ".agents" / "plugins" / PACKAGE_ID


def legacy_skills_path(home_root: Path) -> Path:
    return home_root / ".agents" / "skills"


def default_codex_marketplace_path(home_root: Path) -> Path:
    return home_root / ".agents" / "plugins" / "marketplace.json"


def default_codex_config_path(home_root: Path) -> Path:
