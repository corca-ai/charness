            for tool_id in sorted(set([*support_map.keys(), *doctor_map.keys()]))
        },
    }
    if args.json:
        print(json.dumps(payload, ensure_ascii=False, indent=2))
    else:
        print_tool_human_summary(payload)
    if any(
        isinstance(result, dict)
        and isinstance(result.get("doctor"), dict)
        and result["doctor"].get("doctor_status") in {"missing", "unhealthy", "not-ready", "version-mismatch", "support-missing"}
        for result in payload["results"].values()
    ):
        return 1
    return 0


