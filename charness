def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Thin charness CLI for managed local install, capability resolution, and external tool install/update/doctor flows."
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    def add_common_runtime_args(command: argparse.ArgumentParser) -> None:
        command.add_argument("--home-root", type=Path, default=default_home_root())
        command.add_argument("--repo-root", type=Path, help="Use an explicit existing source checkout instead of the managed default checkout.")
        command.add_argument("--repo-url", default=REPO_URL)
        command.add_argument("--plugin-root", type=Path)
        command.add_argument(
            "--codex-marketplace-path",
            type=Path,
        )
        command.add_argument(
            "--claude-wrapper-path",
            type=Path,
        )
        command.add_argument("--cli-path", type=Path)
        command.add_argument("--skip-cli-install", action="store_true")
        command.add_argument("--skip-claude-wrapper", action="store_true")
        command.add_argument("--json", action="store_true")

    init_parser = subparsers.add_parser(
        "init",
        help="Bootstrap or refresh the managed local install surface, cloning the managed checkout first when it is missing.",
    )
    add_common_runtime_args(init_parser)
    init_parser.set_defaults(func=cmd_init)

    update_parser = subparsers.add_parser(
        "update",
        help="Refresh the installed surface, pulling the managed checkout first by default.",
    )
    add_common_runtime_args(update_parser)
    update_parser.add_argument(
        "--no-pull",
        action="store_true",
        help="Skip the default `git pull --ff-only` when the managed checkout already contains the exact source you want.",
    )
    update_parser.add_argument(
        "--skip-codex-cache-refresh",
        action="store_true",
        help="Do not call Codex app-server `plugin/install` to refresh the enabled local plugin cache after updating the source plugin root.",
    )
    update_parser.add_argument(
        "scope",
        nargs="?",
        choices=["all"],
        help="Also run `charness tool update` for all tracked external integrations after refreshing the charness install surface itself.",
    )
    update_parser.set_defaults(func=cmd_update)

    doctor_parser = subparsers.add_parser("doctor", help="Inspect the managed install surface and host-facing wrappers.")
    doctor_parser.add_argument("--home-root", type=Path, default=default_home_root())
    doctor_parser.add_argument("--repo-root", type=Path, help="Inspect an explicit source checkout instead of the managed default checkout.")
    doctor_parser.add_argument("--plugin-root", type=Path)
    doctor_parser.add_argument(
        "--codex-marketplace-path",
        type=Path,
    )
    doctor_parser.add_argument(
        "--claude-wrapper-path",
        type=Path,
    )
    doctor_parser.add_argument("--cli-path", type=Path)
    doctor_parser.add_argument("--json", action="store_true")
    doctor_parser.add_argument(
        "--write-state",
        action="store_true",
        help="Persist the current doctor snapshot to the machine-local charness state directory for later proof comparison.",
    )
    doctor_parser.set_defaults(func=cmd_doctor)

    version_parser = subparsers.add_parser("version", help="Report the current charness version and recorded install provenance.")
    version_parser.add_argument("--home-root", type=Path, default=default_home_root())
    version_parser.add_argument("--repo-root", type=Path, help="Inspect an explicit source checkout instead of the managed default checkout.")
    version_parser.add_argument("--cli-path", type=Path)
    version_parser.add_argument("--json", action="store_true")
    version_parser.add_argument("--verbose", action="store_true")
    version_parser.add_argument(
        "--check",
        action="store_true",
        help="Refresh the cached latest-release check now instead of only showing recorded state.",
    )
    version_parser.set_defaults(func=cmd_version)

    uninstall_parser = subparsers.add_parser("uninstall", help="Remove the managed local install surface.")
    uninstall_parser.add_argument("--home-root", type=Path, default=default_home_root())
    uninstall_parser.add_argument("--repo-root", type=Path, help="Use an explicit checkout path when `--delete-checkout` is set.")
    uninstall_parser.add_argument("--plugin-root", type=Path)
    uninstall_parser.add_argument(
        "--codex-marketplace-path",
        type=Path,
    )
    uninstall_parser.add_argument(
        "--claude-wrapper-path",
        type=Path,
    )
    uninstall_parser.add_argument("--cli-path", type=Path)
    uninstall_parser.add_argument("--delete-checkout", action="store_true")
    uninstall_parser.add_argument("--delete-cli", action="store_true")
    uninstall_parser.add_argument("--json", action="store_true")
    uninstall_parser.set_defaults(func=cmd_uninstall)

    reset_parser = subparsers.add_parser(
        "reset",
        help="Remove host plugin state for Codex and Claude while preserving the managed checkout and CLI.",
    )
    reset_parser.add_argument("--home-root", type=Path, default=default_home_root())
    reset_parser.add_argument("--repo-root", type=Path, help="Use an explicit checkout path when removing Claude plugin state.")
    reset_parser.add_argument("--plugin-root", type=Path)
    reset_parser.add_argument(
        "--codex-marketplace-path",
        type=Path,
    )
    reset_parser.add_argument(
        "--claude-wrapper-path",
        type=Path,
    )
    reset_parser.add_argument("--cli-path", type=Path)
    reset_parser.add_argument("--json", action="store_true")
    reset_parser.set_defaults(func=cmd_reset)

    task_parser = subparsers.add_parser(
        "task",
        help="Claim, submit, abort, or inspect a repo-local agent task envelope.",
    )
    task_parser.add_argument(
        "--repo-root",
        type=Path,
        default=Path.cwd(),
        help="Repo where .charness/tasks/*.json task state is stored. Defaults to the current working directory.",
    )
    task_parser.add_argument("--json", action="store_true")
    task_subparsers = task_parser.add_subparsers(dest="task_command", required=True)

    def add_task_identity_args(command: argparse.ArgumentParser) -> None:
        command.add_argument("task_id")
        command.add_argument(
            "--agent",
            help="Agent identity recorded in the task. Defaults to CHARNESS_AGENT_ID, CODEX_SESSION_ID, USER, then `agent`.",
        )

    task_claim_parser = task_subparsers.add_parser(
        "claim",
        help="Create a claimed task envelope unless another agent already owns it.",
    )
    add_task_identity_args(task_claim_parser)
    task_claim_parser.add_argument("--summary", default="")
    task_claim_parser.set_defaults(func=cmd_task_claim)

    task_submit_parser = task_subparsers.add_parser(
        "submit",
        help="Mark a claimed task as submitted with structured result metadata.",
    )
    task_submit_parser.add_argument("task_id")
    task_submit_parser.add_argument("--summary", default="")
    task_submit_parser.add_argument("--artifact", action="append", default=[], dest="artifacts")
    task_submit_parser.set_defaults(func=cmd_task_submit)

    task_abort_parser = task_subparsers.add_parser(
        "abort",
        help="Mark a claimed task as aborted with a required reason.",
    )
    task_abort_parser.add_argument("task_id")
    task_abort_parser.add_argument("--reason", required=True)
    task_abort_parser.set_defaults(func=cmd_task_abort)

    task_status_parser = task_subparsers.add_parser(
        "status",
        help="Show one task envelope, or list all repo-local task envelopes.",
    )
    task_status_parser.add_argument("task_id", nargs="?")
    task_status_parser.set_defaults(func=cmd_task_status)

    capability_parser = subparsers.add_parser(
        "capability",
        help="Resolve repo-local logical capabilities into machine-local provider profiles and inspect provider readiness.",
    )
    capability_subparsers = capability_parser.add_subparsers(dest="capability_command", required=True)

    def add_common_capability_args(command: argparse.ArgumentParser) -> None:
        command.add_argument("--home-root", type=Path, default=default_home_root())
        command.add_argument("--repo-root", type=Path, help="Use an explicit charness source checkout instead of the managed default checkout.")
        command.add_argument("--repo-url", default=REPO_URL)
        command.add_argument(
            "--target-repo-root",
            type=Path,
            help="Resolve repo bindings for this target repo. Defaults to the current working directory.",
        )
        command.add_argument("--json", action="store_true")
        command.add_argument("logical_id")

    capability_init_parser = capability_subparsers.add_parser(
        "init",
        help="Scaffold machine-local capability profile and repo binding config files for first use.",
    )
    capability_init_parser.add_argument("--home-root", type=Path, default=default_home_root())
    capability_init_parser.add_argument(
        "--target-repo-root",
        type=Path,
        help="Seed repo-binding examples for this target repo. Defaults to the current working directory.",
    )
    capability_init_parser.add_argument("--force", action="store_true")
    capability_init_parser.add_argument("--json", action="store_true")
    capability_init_parser.set_defaults(func=cmd_capability_init)

    capability_resolve_parser = capability_subparsers.add_parser(
        "resolve",
        help="Resolve one logical capability for the current repo into a profile and provider.",
    )
    add_common_capability_args(capability_resolve_parser)
    capability_resolve_parser.set_defaults(func=cmd_capability_resolve)

    capability_doctor_parser = capability_subparsers.add_parser(
        "doctor",
        help="Resolve one logical capability and inspect the underlying provider state.",
    )
    add_common_capability_args(capability_doctor_parser)
    capability_doctor_parser.set_defaults(func=cmd_capability_doctor)

    capability_env_parser = capability_subparsers.add_parser(
        "env",
        help="Emit shell exports that alias runtime env names from machine-local source env names.",
    )
    add_common_capability_args(capability_env_parser)
    capability_env_parser.set_defaults(func=cmd_capability_env)

    capability_explain_parser = capability_subparsers.add_parser(
        "explain",
        help="Explain which logical capabilities a public skill may need and what the current repo adapter adds.",
    )
    capability_explain_parser.add_argument("--home-root", type=Path, default=default_home_root())
    capability_explain_parser.add_argument("--repo-root", type=Path, help="Use an explicit charness source checkout instead of the managed default checkout.")
    capability_explain_parser.add_argument("--repo-url", default=REPO_URL)
    capability_explain_parser.add_argument(
        "--target-repo-root",
        type=Path,
        help="Inspect repo-local adapter context for this target repo. Defaults to the current working directory.",
    )
    capability_explain_parser.add_argument("--json", action="store_true")
    capability_explain_parser.add_argument("skill_id")
    capability_explain_parser.set_defaults(func=cmd_capability_explain)

    tool_parser = subparsers.add_parser(
        "tool",
        help="Inspect, install, update, or sync external tool integrations that charness-managed skills depend on.",
    )
    tool_subparsers = tool_parser.add_subparsers(dest="tool_command", required=True)

    def add_common_tool_args(command: argparse.ArgumentParser) -> None:
        command.add_argument("--home-root", type=Path, default=default_home_root())
        command.add_argument("--repo-root", type=Path, help="Use an explicit existing source checkout instead of the managed default checkout.")
        command.add_argument("--repo-url", default=REPO_URL)
        command.add_argument("--json", action="store_true")
        command.add_argument("tool_ids", nargs="*")

    def add_support_sync_args(command: argparse.ArgumentParser) -> None:
        command.add_argument("--upstream-checkout", action="append", default=[])

    tool_doctor_parser = tool_subparsers.add_parser(
        "doctor",
        help="Write machine-readable doctor state for one or more external tools.",
    )
    add_common_tool_args(tool_doctor_parser)
    tool_doctor_parser.add_argument(
        "--no-write-locks",
        action="store_true",
        help="Skip updating integrations/locks/*.json when you only want a read-only probe.",
    )
    tool_doctor_parser.set_defaults(func=cmd_tool_doctor)

    tool_sync_support_parser = tool_subparsers.add_parser(
        "sync-support",
        help="Refresh cache-backed support skill materialization for one or more external tools.",
    )
    add_common_tool_args(tool_sync_support_parser)
    add_support_sync_args(tool_sync_support_parser)
    tool_sync_support_parser.add_argument("--dry-run", action="store_true")
    tool_sync_support_parser.set_defaults(func=cmd_tool_sync_support)

    tool_install_parser = tool_subparsers.add_parser(
        "install",
        help="Attempt tool installation where the manifest allows it, otherwise persist install guidance and doctor state.",
    )
    add_common_tool_args(tool_install_parser)
    add_support_sync_args(tool_install_parser)
    tool_install_parser.add_argument("--dry-run", action="store_true")
    tool_install_parser.add_argument(
        "--skip-sync-support",
        action="store_true",
        help="Skip support skill rematerialization after install guidance or execution.",
    )
    tool_install_parser.set_defaults(func=cmd_tool_install)

    tool_update_parser = tool_subparsers.add_parser(
        "update",
        help="Attempt manifest-declared external tool updates, then refresh support skill materialization and doctor state.",
    )
    add_common_tool_args(tool_update_parser)
    add_support_sync_args(tool_update_parser)
    tool_update_parser.add_argument("--dry-run", action="store_true")
    tool_update_parser.add_argument(
        "--skip-sync-support",
        action="store_true",
        help="Skip support skill rematerialization after update.",
    )
    tool_update_parser.set_defaults(func=cmd_tool_update)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    maybe_record_self_version_state(args)
    return args.func(args)


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except CharnessError as exc:
        print(str(exc), file=sys.stderr)
        raise SystemExit(1)
